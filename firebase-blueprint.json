{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "Represents a news article",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "lead": { "type": "string" },
        "content": { "type": "array", "items": { "type": "string" } },
        "pageNumbers": { "type": "array", "items": { "type": "number" } },
        "imageCaption": { "type": "string" }
      },
      "required": ["id", "title", "content"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "Article" },
      "description": "Collection of articles"
    }
  }
}
